# ============================================
# World Monitor — Self-Hosted Environment
# ============================================
# Copy to .env.local for local self-hosted development:
#
#   cp .env.selfhosted.example .env.local
#
# This template is intentionally focused on self-hosted/full-mode operation.
# It omits most hosted SaaS billing/auth variables (Clerk, Dodo, Convex entitlements).
# Fill only the providers you actually need; the app degrades gracefully when
# an upstream source is not configured.
# ============================================


# ------ Deployment Mode ------

# Client-side deployment mode for the capability layer.
VITE_DEPLOYMENT_MODE=self_hosted

# Server-side deployment mode for gateway capability checks.
DEPLOYMENT_MODE=self_hosted

# Comma-separated feature capabilities enabled in self-hosted mode.
# Supported values:
#   premium_ui
#   advanced_market_analysis
#   regional_intelligence
#   resilience
#   supply_chain_advanced
#   scenario_engine
#   ai_enrichment
VITE_SELF_HOSTED_FEATURES=premium_ui,advanced_market_analysis,regional_intelligence,resilience,supply_chain_advanced,scenario_engine,ai_enrichment
SELF_HOSTED_FEATURES=premium_ui,advanced_market_analysis,regional_intelligence,resilience,supply_chain_advanced,scenario_engine,ai_enrichment


# ------ Core Infrastructure ------

# Shared cache / seed storage.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Server-side relay URL used by API handlers.
WS_RELAY_URL=

# Base URL for WorldMonitor RPC calls made by the relay (including widget-agent tools).
# For docker-compose self-hosted, this defaults to the local stack service.
WORLDMONITOR_RPC_BASE_URL=http://worldmonitor:8080

# Optional browser fallback URL for local/dev use.
VITE_WS_RELAY_URL=

# Shared secret between API and relay.
RELAY_SHARED_SECRET=
RELAY_AUTH_HEADER=x-relay-key


# ------ AI Providers ------

# Required for the PRO widget builder (/api/widget-agent → relay /widget-agent).
ANTHROPIC_API_KEY=

# Fast primary summarization / brief generation.
GROQ_API_KEY=

# Secondary hosted LLM fallback.
OPENROUTER_API_KEY=

# Generic OpenAI-compatible self-hosted LLM endpoint.
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=

# Ollama / LM Studio style local endpoint.
OLLAMA_API_URL=
OLLAMA_MODEL=


# ------ Widget Builder (PRO) ------

# Shared secrets used to access the relay's /widget-agent endpoints.
# In self-hosted mode you normally don't need to set these (compose defaults
# are fine), but setting custom values is recommended if you expose the relay.
WIDGET_AGENT_KEY=
PRO_WIDGET_KEY=


# ------ Search / AI Enrichment ------

# At least one is recommended for advanced market analysis and AI enrichment.
EXA_API_KEYS=
BRAVE_API_KEYS=
SERPAPI_API_KEYS=


# ------ Markets / Economics / Energy ------

FINNHUB_API_KEY=
FRED_API_KEY=
EIA_API_KEY=
WTO_API_KEY=
COINGECKO_API_KEY=


# ------ Conflict / Intelligence / Resilience ------

# Recommended ACLED OAuth flow for automatic refresh:
ACLED_EMAIL=
ACLED_PASSWORD=

# Optional static fallback if you do not want to store email/password.
ACLED_ACCESS_TOKEN=

UCDP_ACCESS_TOKEN=


# ------ Cyber / Outages ------

CLOUDFLARE_API_TOKEN=
URLHAUS_AUTH_KEY=
OTX_API_KEY=
ABUSEIPDB_API_KEY=


# ------ Maritime / Aviation / Military ------

AISSTREAM_API_KEY=
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
WINGBITS_API_KEY=
AVIATIONSTACK_API=
ICAO_API_KEY=
TRAVELPAYOUTS_API_TOKEN=
CORRIDOR_RISK_API_KEY=


# ------ Wildfire / Air Quality / Webcam / Health ------

NASA_FIRMS_API_KEY=
OPENAQ_API_KEY=
WAQI_API_KEY=
WINDY_API_KEY=
RELIEFWEB_APPNAME=


# ------ Optional Storage / Seed Infra ------

CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_TRACE_BUCKET=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_REGION=auto
CLOUDFLARE_R2_TRACE_PREFIX=seed-data/forecast-traces


# ------ UI / Client Runtime ------

VITE_VARIANT=full
VITE_WS_API_URL=
VITE_SENTRY_DSN=
VITE_MAP_INTERACTION_MODE=3d
VITE_PMTILES_URL=
VITE_PMTILES_URL_PUBLIC=
VITE_CLOUD_PREFS_ENABLED=false
VITE_TELEGRAM_BOT_USERNAME=WorldMonitorBot


# ------ Optional Legacy Hosted Compatibility ------

# Not required for self-hosted capability mode.
# Keep empty unless you explicitly still use hosted premium/auth paths.
WORLDMONITOR_API_KEY=
WORLDMONITOR_VALID_KEYS=
