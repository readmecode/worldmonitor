# =============================================================================
# AIS Relay Sidecar
# =============================================================================
# Runs scripts/ais-relay.cjs as a standalone container.
# Dependencies: ws (WebSocket), telegram (OSINT polling), plus others in
# scripts/package.json (fast-xml-parser, @anthropic-ai/sdk, etc.)
# Set AISSTREAM_API_KEY in docker-compose.yml or Railway env.
# =============================================================================

FROM node:22-bookworm-slim

# curl required by OREF polling (Node.js JA3 fingerprint blocked by Akamai; curl passes)
# Debian slim reduces native-addon pain vs Alpine/musl (prebuilt binaries exist).
RUN apt-get update \
  && apt-get install -y --no-install-recommends curl ca-certificates python3 make g++ \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install scripts/ runtime dependencies (telegram, ws, fast-xml-parser, etc.)
COPY scripts/package.json scripts/package-lock.json ./scripts/
# ws uses optional peer deps (bufferutil / utf-8-validate) for performance.
# In Alpine builds they commonly require node-gyp. Omit peer deps so self-hosted
# users don't need a build toolchain.
RUN npm ci --prefix scripts --omit=dev --omit=optional --omit=peer

# Copy the full scripts/ tree so the same image can run the relay and the
# self-hosted seed-worker (which invokes many seed scripts).
COPY scripts/ ./scripts/

# Self-hosted seed worker entrypoint (used by docker-compose.yml)
COPY docker/seed-worker.sh /app/seed-worker.sh
RUN chmod +x /app/seed-worker.sh

# Shared helper required by the relay (rss-allowed-domains.cjs)
COPY shared/ ./shared/

# Data files required by the relay (telegram-channels.json, etc.)
COPY data/ ./data/

EXPOSE 3004

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD curl -fsS --max-time 4 http://127.0.0.1:3004/health >/dev/null || exit 1

CMD ["node", "scripts/ais-relay.cjs"]
